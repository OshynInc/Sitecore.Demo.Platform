@using System.Linq
@model Sitecore.Demo.Platform.Feature.ExperienceAccelerator.Models.PageListModel

<div class="component page-list page-list nysif-news-featured col-sm-12">
	<div class="component-content">
		@if (Model.Item == null || Model.Items == null || Model.Items.Count == 0)
		{
			if (Sitecore.Context.PageMode.IsExperienceEditor)
			{
				<p>[Page List: select a news folder datasource]</p>
			}
			return;
		}

		<div class="news-main">
			<div class="section-heading">@Model.Heading</div>
			<p class="section-sub" style="margin-bottom:28px;">@Model.Subheading</p>

			@{
				var featured = Model.Items[0];
				var rest = Model.Items.Skip(1).Take(2).ToList();
			}

			<div class="news-featured">
				<div class="thumb"></div>
				<div>
					@if (!string.IsNullOrWhiteSpace(featured.Category))
					{
						<div class="news-category">@featured.Category</div>
					}
					<div class="news-title">
						<a href="@featured.Url">@featured.Title</a>
					</div>
					@if (!string.IsNullOrWhiteSpace(featured.Summary))
					{
						<div class="news-desc">@featured.Summary</div>
					}
					@if (!string.IsNullOrWhiteSpace(featured.PublishDate))
					{
						<div class="news-meta">@featured.PublishDate</div>
					}
				</div>
			</div>

			@if (rest.Count > 0)
			{
				<div class="news-row">
					@foreach (var item in rest)
					{
						<div class="news-row-item">
							<div class="thumb-sm"></div>
							<div>
								@if (!string.IsNullOrWhiteSpace(item.Category))
								{
									<div class="news-category">@item.Category</div>
								}
								<div class="news-title-sm">
									<a href="@item.Url">@item.Title</a>
								</div>
								@if (!string.IsNullOrWhiteSpace(item.PublishDate))
								{
									<div class="news-meta">@item.PublishDate</div>
								}
							</div>
						</div>
					}
				</div>
			}

			<div class="news-viewall">
				<a href="#">View all news and press releases &rarr;</a>
			</div>
		</div>
	</div>
</div>
