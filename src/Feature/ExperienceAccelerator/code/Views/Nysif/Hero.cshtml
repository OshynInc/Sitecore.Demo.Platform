@using Sitecore.Mvc
@model Sitecore.Demo.Platform.Feature.ExperienceAccelerator.Models.HeroModel

<div class="component hero hero nysif-hero-homepage col-sm-12 nysif-hero-homepage">
	<div class="component-content">
		@if (Model.Item == null)
		{
			if (Sitecore.Context.PageMode.IsExperienceEditor)
			{
				<p>[Hero: select a datasource]</p>
			}
			return;
		}
		<div class="hero-left">
			@if (!string.IsNullOrWhiteSpace(Model.Supertitle))
			{
				<div class="eyebrow">@Model.Supertitle</div>
			}
			@if (!string.IsNullOrWhiteSpace(Model.TitleHtml))
			{
				<h1>@Html.Raw(Model.TitleHtml)</h1>
			}
			@if (!string.IsNullOrWhiteSpace(Model.Text))
			{
				<p class="hero-sub">@Html.Raw(Model.Text)</p>
			}
			<div class="hero-ctas">
				<a href="@Model.PrimaryCtaUrl" class="btn btn-white">@Model.PrimaryCtaText</a>
				<a href="@Model.SecondaryCtaUrl" class="btn btn-outline">@Model.SecondaryCtaText</a>
			</div>
			@if (Model.Stats != null && Model.Stats.Count > 0)
			{
				<hr class="hero-divider" />
				<div class="stats">
					@foreach (var stat in Model.Stats)
					{
						<div class="stat">
							<div class="stat-value">@stat.Value</div>
							<div class="stat-label">@stat.Label</div>
						</div>
					}
				</div>
			}
		</div>
	</div>
</div>
