@using Sitecore.Mvc
@using Sitecore.Demo.Platform.Foundation.SitecoreExtensions.Extensions
@model Sitecore.Demo.Platform.Feature.ExperienceAccelerator.Models.NewsSidebarModel

<div class="component nysif-news-sidebar col-sm-12">
	<div class="component-content">
		@if (Model.Item == null)
		{
			if (Sitecore.Context.PageMode.IsExperienceEditor)
			{
				<p>[News Sidebar: select the Sidebar datasource]</p>
			}
			return;
		}

		<aside class="news-side">
			@if ((Model.Notices != null && Model.Notices.Count > 0) || Sitecore.Context.PageMode.IsExperienceEditor)
			{
				<div class="side-heading">
					@if (Model.NoticesFolder != null)
					{
						using (Html.BeginEditFrame(Model.NoticesFolder.ID.ToString(), "/sitecore/content/Applications/WebEdit/Edit Frame Buttons/Default"))
						{
							@Html.Sitecore().Field("Title", Model.NoticesFolder)
						}
					}
					else
					{
						@Model.NoticesHeading
					}
				</div>
				foreach (var notice in Model.Notices)
				{
					using (Html.BeginEditFrame(notice.Item.ID.ToString(), "/sitecore/content/Applications/WebEdit/Edit Frame Buttons/Default"))
					{
						<div class="notice-item">
							@* DotColor is a plain class token — Field() can trip Content Hub DAM. Edit via Edit Frame. *@
							<div class="notice-dot @notice.DotClass"></div>
							<div>
								<div class="notice-date">@Html.Sitecore().Field("Date", notice.Item)</div>
								<div class="notice-text">
									@if (Sitecore.Context.PageMode.IsExperienceEditor || !string.IsNullOrWhiteSpace(notice.Item["Text"]))
									{
										@Html.Sitecore().Field("Text", notice.Item)
									}
									else
									{
										@Html.Sitecore().Field("Link", notice.Item)
									}
								</div>
							</div>
						</div>
					}
				}
			}

			@if ((Model.SafetyItems != null && Model.SafetyItems.Count > 0) || Sitecore.Context.PageMode.IsExperienceEditor)
			{
				<div class="safety-heading">
					@if (Model.SafetyFolder != null)
					{
						using (Html.BeginEditFrame(Model.SafetyFolder.ID.ToString(), "/sitecore/content/Applications/WebEdit/Edit Frame Buttons/Default"))
						{
							@Html.Sitecore().Field("Title", Model.SafetyFolder)
						}
					}
					else
					{
						@Model.SafetyHeading
					}
				</div>
				foreach (var item in Model.SafetyItems)
				{
					using (Html.BeginEditFrame(item.Item.ID.ToString(), "/sitecore/content/Applications/WebEdit/Edit Frame Buttons/Default"))
					{
						<div class="safety-item">
							@* Icon is a plain glyph key — Field() crashes Content Hub DAM. Edit via Edit Frame. *@
							<div class="safety-icon">@item.Icon</div>
							<div>
								<div class="safety-title">
									@if (Sitecore.Context.PageMode.IsExperienceEditor || !string.IsNullOrWhiteSpace(item.Item["Title"]))
									{
										@Html.Sitecore().Field("Title", item.Item)
									}
									else
									{
										@Html.Sitecore().Field("Link", item.Item)
									}
								</div>
								<div class="safety-sub">@Html.Sitecore().Field("Subtitle", item.Item)</div>
							</div>
						</div>
					}
				}
			}
		</aside>
	</div>
</div>
