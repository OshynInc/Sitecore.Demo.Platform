@model Sitecore.Demo.Platform.Feature.ExperienceAccelerator.Models.NewsSidebarModel

<div class="component nysif-news-sidebar col-sm-12">
	<div class="component-content">
		@if (Model.Item == null)
		{
			if (Sitecore.Context.PageMode.IsExperienceEditor)
			{
				<p>[News Sidebar: select the Sidebar datasource]</p>
			}
			return;
		}

		<aside class="news-side">
			@if (Model.Notices != null && Model.Notices.Count > 0)
			{
				<div class="side-heading">@Model.NoticesHeading</div>
				foreach (var notice in Model.Notices)
				{
					<div class="notice-item">
						<div class="notice-dot @notice.DotClass"></div>
						<div>
							@if (!string.IsNullOrWhiteSpace(notice.Date))
							{
								<div class="notice-date">@notice.Date</div>
							}
							<div class="notice-text">@notice.Text</div>
						</div>
					</div>
				}
			}

			@if (Model.SafetyItems != null && Model.SafetyItems.Count > 0)
			{
				<div class="safety-heading">@Model.SafetyHeading</div>
				foreach (var item in Model.SafetyItems)
				{
					<div class="safety-item">
						<div class="safety-icon">@item.Icon</div>
						<div>
							<div class="safety-title">@item.Title</div>
							@if (!string.IsNullOrWhiteSpace(item.Subtitle))
							{
								<div class="safety-sub">@item.Subtitle</div>
							}
						</div>
					</div>
				}
			}
		</aside>
	</div>
</div>
